diff --git a/src/corelib/io/forkfd_qt.c b/src/corelib/io/forkfd_qt.c
index 9669af8e..2bd4156a 100644
--- a/src/corelib/io/forkfd_qt.c
+++ b/src/corelib/io/forkfd_qt.c
@@ -7,6 +7,57 @@
 #endif
 #include <QtCore/qglobal.h>
 
+#if defined(__OPENHOBBYOS__)
+
+#include <sys/resource.h>
+
+#define FORKFD_NO_SPAWNFD
+#if defined(QT_NO_DEBUG) && !defined(NDEBUG)
+#  define NDEBUG
+#endif
+
+#include <forkfd.h>
+#include <errno.h>
+
+int forkfd(int flags, pid_t *ppid)
+{
+    (void)flags;
+    if (ppid)
+        *ppid = -1;
+    errno = ENOSYS;
+    return -1;
+}
+
+int vforkfd(int flags, pid_t *ppid, int (*childFn)(void *), void *token)
+{
+    (void)flags;
+    (void)childFn;
+    (void)token;
+    if (ppid)
+        *ppid = -1;
+    errno = ENOSYS;
+    return -1;
+}
+
+int forkfd_wait4(int ffd, struct forkfd_info *info, int options, struct rusage *rusage)
+{
+    (void)ffd;
+    (void)info;
+    (void)options;
+    (void)rusage;
+    errno = EINVAL;
+    return -1;
+}
+
+int forkfd_close(int ffd)
+{
+    (void)ffd;
+    errno = EINVAL;
+    return -1;
+}
+
+#else
+
 #define FORKFD_NO_SPAWNFD
 #if defined(QT_NO_DEBUG) && !defined(NDEBUG)
 #  define NDEBUG
@@ -14,3 +65,5 @@
 
 #include <forkfd.h>
 #include "../../3rdparty/forkfd/forkfd.c"
+
+#endif
