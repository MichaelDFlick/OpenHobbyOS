#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
SYSROOT=${OPENHOBBYOS_SYSROOT:-"$ROOT/build/ports/sysroot"}
TARGET_SYSROOT="$SYSROOT/i686-elf"
SPECS="$SYSROOT/lib/openhobbyos.specs"

args=(-m32 -fno-pic -fno-pie -fomit-frame-pointer -D__OPENHOBBYOS__ -D_GLIBCXX_HOSTED=0)

if [[ -d "$SYSROOT" ]]; then
    args+=(--sysroot="$SYSROOT")
fi

if [[ -f "$SPECS" ]]; then
    args+=(-specs="$SPECS")
fi

# C++ headers must come BEFORE C headers so that #include_next works
# e.g. <cmath> uses #include_next <math.h> and skips directories before it
CXX_VER=13
if [[ -d "$SYSROOT/include/c++/$CXX_VER" ]]; then
    args+=(-isystem "$SYSROOT/include/c++/$CXX_VER")
fi
if [[ -d "$SYSROOT/include/i386-linux-gnu/c++/$CXX_VER" ]]; then
    args+=(-isystem "$SYSROOT/include/i386-linux-gnu/c++/$CXX_VER")
fi
if [[ -d "$SYSROOT/include/i386-linux-gnu/c++/$CXX_VER/bits" ]]; then
    args+=(-isystem "$SYSROOT/include/i386-linux-gnu/c++/$CXX_VER/bits")
fi

if [[ -d "$TARGET_SYSROOT/include" ]]; then
    args+=(-isystem "$TARGET_SYSROOT/include")
fi

if [[ -f "$TARGET_SYSROOT/include/openhobbyos/features.h" ]]; then
    args+=(-include "$TARGET_SYSROOT/include/openhobbyos/features.h")
fi

if [[ -d "$TARGET_SYSROOT/lib" ]]; then
    args+=(-L"$TARGET_SYSROOT/lib" -B"$TARGET_SYSROOT/lib")
fi

exec g++ "${args[@]}" "$@"
